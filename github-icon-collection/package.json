{
  "name": "github-icon-collection",
  "version": "1.0.0",
  "description": "从 GitHub 收集和管理开源图标的自动化仓库",
  "main": "index.js",
  "scripts": {
    "fetch": "node scripts/fetch-icons.js",
    "optimize": "node scripts/optimize.js",
    "sprite": "node scripts/build-sprite.js",
    "font": "node scripts/generate-font.js",
    "preview": "node scripts/build-preview.js",
    "build": "npm run fetch && npm run optimize && npm run sprite && npm run font && npm run preview",
    "clean": "rm -rf dist .temp-* icons/ui/* icons/brands/* icons/flags/*"
  },
  "keywords": [
    "icons",
    "svg",
    "icon-font",
    "sprite",
    "github",
    "collection"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "svgo": "^3.2.0",
    "svg2ttf": "^6.0.3",
    "svgicons2svgfont": "^12.0.0",
    "ttf2eot": "^3.1.0",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^4.0.5"
  }
}